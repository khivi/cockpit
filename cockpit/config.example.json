{
  "repos": [
    {
      "name": "myrepo",
      "path": "/absolute/path/to/main/repo",
      "branch_prefix": "yourusername/",
      "default_base": "main",
      "sidebar_color": "Blue",
      "review_prs": false,
      "tickets": {
        "provider": "linear",
        "keys": ["TEAM"],
        "close_on_merge": false,
        "merge_done_state": "Done"
      }
    }
  ],
  "slow_poll_interval_seconds": 300,
  "fast_poll_interval_seconds": 30,
  "autoclose_age_days": 14,
  "orphan_nudge_grace_hours": 4,
  "prompt_prefix": "",
  "use_cship": false,
  "use_slack": false,
  "check_update": true,
  "tool": "auto",
  "theme": "dark",
  "tui_theme": "textual-dark"
}
