{
  "repos": [
    {
      "name": "myrepo",
      "path": "/absolute/path/to/main/repo",
      "branch_prefix": "yourusername/",
      "default_base": "main",
      "sidebar_color": "Blue",
      "review_prs": false,
      "skills": {
        "review": "/pr-review"
      },
      "review_external": false,
      "dependabot": false,
      "tickets": {
        "provider": "linear",
        "keys": ["TEAM"],
        "close_on_merge": false,
        "merge_done_state": "Done"
      }
    },
    {
      "name": "my-github-repo",
      "path": "/absolute/path/to/another/repo",
      "branch_prefix": "yourusername/",
      "default_base": "main",
      "sidebar_color": "Green",
      "tickets": {
        "provider": "github",
        "dev_done_label": "ready for review",
        "start_label": "in progress",
        "close_on_merge": false
      }
    },
    {
      "name": "my-jira-repo",
      "path": "/absolute/path/to/a/third/repo",
      "branch_prefix": "yourusername/",
      "default_base": "main",
      "tickets": {
        "provider": "jira",
        "site_url": "https://yourteam.atlassian.net",
        "email": "you@example.com",
        "dev_done_status": "Dev Done",
        "merge_done_status": "Done",
        "close_on_merge": false
      }
    },
    {
      "name": "my-trello-repo",
      "path": "/absolute/path/to/a/fourth/repo",
      "branch_prefix": "yourusername/",
      "default_base": "main",
      "tickets": {
        "provider": "trello",
        "dev_done_list": "Review",
        "merge_done_list": "Done",
        "close_on_merge": false
      }
    },
    {
      "name": "scratch",
      "path": "/absolute/path/to/inplace/repo",
      "branch_prefix": "yourusername/",
      "default_base": "main",
      "use_worktree": false
    }
  ],
  "slow_poll_interval_seconds": 300,
  "fast_poll_interval_seconds": 30,
  "autoclose_age_days": 14,
  "orphan_nudge_grace_hours": 4,
  "linear_state_ttl_seconds": 900,
  "linear_identity_ttl_seconds": 3600,
  "skills": {
    "session": "/session-coordination",
    "review": "/review"
  },
  "use_cship": false,
  "use_slack": false,
  "tool": "auto",
  "theme": "dark",
  "tui_theme": "textual-dark",
  "statusline_hide": ["cost", "session-time"]
}
