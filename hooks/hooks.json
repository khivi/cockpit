{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "cockpit update --sync || true" }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "cockpit statusline || true" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/cmux-idle-pill.sh stop" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/cmux-idle-pill.sh prompt" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "ScheduleWakeup|CronCreate|CronUpdate",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/cmux-idle-pill.sh loop-set" }
        ]
      },
      {
        "matcher": "CronDelete",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/cmux-idle-pill.sh loop-clear" }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/cmux-idle-pill.sh loop-clear" }
        ]
      }
    ]
  }
}
